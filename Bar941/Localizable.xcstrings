    "editor.adjustment.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passe Position und Groesse von Uhrzeit und rechten Symbolen an. Die obere Vorschau aktualisiert sich sofort."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adjust the position and size of the time and right-side icons to update the top preview instantly."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adjust the position and size of the time and right-side icons to update the top preview instantly."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adjust the position and size of the time and right-side icons to update the top preview instantly."
          }
        },
        "en-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adjust the position and size of the time and right-side icons to update the top preview instantly."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajusta la posicion y el tamano de la hora y de los iconos de la derecha para actualizar al instante la vista superior."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajusta la posicion y el tamano de la hora y de los iconos de la derecha para actualizar al instante la vista superior."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajustez la position et la taille de l'heure et des icones de droite pour mettre a jour instantanement l'aperçu superieur."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regola posizione e dimensione dell'ora e delle icone a destra per aggiornare subito l'anteprima superiore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "時間と右側アイコン群の位置・サイズを調整すると、上部拡大プレビューにすぐ反映されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "시간과 오른쪽 아이콘의 위치 및 크기를 조정하면 상단 확대 미리보기에 바로 반영됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajuste a posicao e o tamanho do horario e dos icones da direita para atualizar a visualizacao superior na hora."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajuste a posicao e o tamanho da hora e dos icones do lado direito para atualizar de imediato a pre-visualizacao superior."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "调整时间和右侧图标的位置与大小，顶部放大预览会立即更新。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "調整時間與右側圖示的位置和大小後，頂部放大預覽會立即更新。"
          }
        }
      }
    },
